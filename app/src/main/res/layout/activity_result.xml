<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- ── Toolbar ─────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_dark"
        android:elevation="4dp"
        app:title="Analysis Result"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- ── Scrollable content ──────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── SUMMARY CARD ──────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_result_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_result_description"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:lineSpacingMultiplier="1.4" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── HIGH RISK BLOCK ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_high_risk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#B71C1C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_high_risk_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ High Risk"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFCDD2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_high_risk_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#FFEBEE"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── MODERATE BLOCK ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_moderate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E65100">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_moderate_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️ Moderate"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFE0B2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_moderate_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#FFF3E0"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── SAFE BLOCK ─────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_safe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1B5E20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tv_safe_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ Safe"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#A5D6A7"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_safe_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#E8F5E9"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Scan Again button ─────────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_again"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="8dp"
                android:text="Scan Another Product"
                android:textColor="@color/white"
                android:textSize="15sp"
                app:backgroundTint="@color/surface_elevated"
                app:cornerRadius="28dp"
                app:strokeColor="@color/white"
                app:strokeWidth="1.5dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
