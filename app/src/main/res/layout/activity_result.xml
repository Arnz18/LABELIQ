<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Toolbar ─────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background"
        android:elevation="0dp"
        app:title="Analysis"
        app:titleTextColor="@color/on_surface"
        app:titleTextAppearance="@style/ToolbarTitle"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- ── VERDICT HERO CARD ────────────────────────── -->
            <FrameLayout
                android:id="@+id/card_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:background="@drawable/bg_surface_card">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="28dp"
                    android:gravity="center_horizontal">

                    <!-- Emoji icon -->
                    <TextView
                        android:id="@+id/tv_result_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="56sp"
                        android:layout_marginBottom="12dp" />

                    <!-- Verdict title -->
                    <TextView
                        android:id="@+id/tv_result_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="30sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="-0.03"
                        android:gravity="center"
                        android:layout_marginBottom="8dp" />

                    <!-- Score badge -->
                    <TextView
                        android:id="@+id/tv_result_score"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_secondary_container"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:background="@drawable/bg_score_badge"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="4dp"
                        android:layout_marginBottom="20dp" />

                    <!-- Divider line -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginBottom="20dp" />

                    <!-- AI Verdict text -->
                    <TextView
                        android:id="@+id/tv_verdict"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="15sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="start"
                        android:lineSpacingMultiplier="1.6" />
                </LinearLayout>
            </FrameLayout>

            <!-- ── CONCERNS CARD ─────────────────────────────── -->
            <LinearLayout
                android:id="@+id/card_high_risk"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:background="@drawable/bg_concern_card"
                android:padding="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠"
                        android:textSize="16sp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_high_risk_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Concerns"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/error"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_high_risk_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- ── BENEFITS CARD ─────────────────────────────── -->
            <LinearLayout
                android:id="@+id/card_safe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:background="@drawable/bg_safe_card"
                android:padding="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓"
                        android:textSize="16sp"
                        android:textColor="@color/secondary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_safe_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Benefits"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/secondary"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_safe_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- ── NEUTRAL CARD ──────────────────────────────── -->
            <LinearLayout
                android:id="@+id/card_moderate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="28dp"
                android:visibility="gone"
                android:background="@drawable/bg_surface_card"
                android:padding="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="≈"
                        android:textSize="18sp"
                        android:textColor="@color/tertiary"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:id="@+id/tv_moderate_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Neutral Ingredients"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/tertiary"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="0.05" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_moderate_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="15sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- ── SCAN AGAIN BUTTON ─────────────────────────── -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_scan_again"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Scan Another Product"
                android:textColor="@color/on_surface"
                android:textSize="16sp"
                android:fontFamily="@font/plus_jakarta_sans"
                app:backgroundTint="@color/surface_container_highest"
                app:cornerRadius="16dp" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
