<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingBottom="48dp">

        <!-- ── Hero Section ─────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="64dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🏷️"
                android:textSize="56sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tailor Your Experience"
                android:textColor="@color/on_surface"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="-0.04"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tell us about yourself so we can provide hyper-personalised nutrition intelligence."
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.5" />
        </LinearLayout>

        <!-- ── NAME Card ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YOUR NAME"
                android:textColor="@color/brand_red"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="12dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                app:hintEnabled="false">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:hint="Enter your name"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline"
                    android:inputType="textPersonName"
                    android:imeOptions="actionDone" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- ── DIETARY FLAGS Card ─────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DIETARY FLAGS"
                android:textColor="@color/brand_red"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="16dp" />

            <!-- Diabetic -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🩸  Diabetic"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_diabetic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <!-- Vegan -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🌿  Vegan"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_vegan"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

            <!-- Nut Allergy -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="🥜  Nut Allergy"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switch_nut_allergy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>
        </LinearLayout>

        <!-- ── PERSONALIZATION Card ───────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:orientation="vertical"
            android:background="@drawable/bg_surface_card"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PERSONALIZATION (OPTIONAL)"
                android:textColor="@color/brand_red"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:layout_marginBottom="16dp" />

            <!-- Conditions -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_conditions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Health conditions (comma separated)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Allergies -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_allergies"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Allergies (comma separated)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Diet Goal -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_diet_goal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Diet Goal (fat_loss, muscle_gain, balanced)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Lifestyle -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_lifestyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Lifestyle (athlete, normal)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Preferences -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_preferences"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Preferences (comma separated)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Avoid Tags -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant"
                android:layout_marginBottom="12dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_avoid_tags"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Avoid tags (comma separated)"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Custom Note -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxStrokeColor="@color/outline_variant">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_custom_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Custom note (e.g. avoid sugar and junk)"
                    android:minLines="2"
                    android:maxLines="4"
                    android:inputType="textMultiLine"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:textColorHint="@color/outline" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>

        <!-- ── CTA Button ─────────────────────────────────────── -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_continue"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Begin My Journey →"
            android:textColor="@color/white"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            app:cornerRadius="16dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
