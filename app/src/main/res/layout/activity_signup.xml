<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingTop="64dp"
        android:paddingBottom="40dp">

        <!-- App name -->
        <TextView
            android:id="@+id/tv_signup_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/accent_green"
            android:textSize="36sp"
            android:textStyle="bold"
            android:letterSpacing="0.08"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Dynamic tagline (changes per step) -->
        <TextView
            android:id="@+id/tv_signup_tagline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Create your account"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_signup_app_name" />

        <!-- ── Step indicator ──────────────────────────────────────────── -->
        <LinearLayout
            android:id="@+id/ll_step_indicator"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_signup_tagline">

            <View
                android:id="@+id/view_step1_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/step_dot_active" />

            <View
                android:layout_width="48dp"
                android:layout_height="2dp"
                android:layout_marginHorizontal="6dp"
                android:background="@color/surface_elevated" />

            <View
                android:id="@+id/view_step2_dot"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/step_dot_inactive" />

        </LinearLayout>

        <!-- Card container -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_signup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/surface_dark"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/surface_elevated"
            app:strokeWidth="1dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ll_step_indicator">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- STEP 1: User Details                                   -->
                <!-- ══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layout_step1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <!-- Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_name"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_name"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Jane Doe"
                            android:inputType="textPersonName|textCapWords"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:imeOptions="actionNext" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_email"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        app:hintEnabled="false">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_email"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="you@example.com"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:imeOptions="actionNext" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Password"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="6dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_password"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        app:hintEnabled="false"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_password"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:hint="Min. 6 characters"
                            android:inputType="textPassword"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:imeOptions="actionDone" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Step 1 error -->
                    <TextView
                        android:id="@+id/tv_step1_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text=""
                        android:textColor="@color/error"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Next button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_next"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="24dp"
                        android:text="Next →"
                        android:textSize="15sp"
                        android:textColor="@color/background_dark"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent_green"
                        app:cornerRadius="26dp" />

                </LinearLayout>

                <!-- ══════════════════════════════════════════════════════ -->
                <!-- STEP 2: Preferences                                    -->
                <!-- ══════════════════════════════════════════════════════ -->
                <LinearLayout
                    android:id="@+id/layout_step2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <!-- ── Section: Dietary flags ─────────────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIETARY FLAGS"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="12dp" />

                    <!-- Diabetic toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🩸  Diabetic"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_diabetic"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:thumbTint="@color/accent_green"
                            app:trackTint="@color/surface_elevated" />
                    </LinearLayout>

                    <!-- Vegan toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🌿  Vegan"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_vegan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:thumbTint="@color/accent_green"
                            app:trackTint="@color/surface_elevated" />
                    </LinearLayout>

                    <!-- Nut Allergy toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🥜  Nut Allergy"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/switch_nut_allergy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="false"
                            app:thumbTint="@color/accent_green"
                            app:trackTint="@color/surface_elevated" />
                    </LinearLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_elevated"
                        android:layout_marginBottom="20dp" />

                    <!-- ── Section: Health Conditions (chips) ────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="HEALTH CONDITIONS"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_conditions"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_condition_diabetes"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Diabetes"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_condition_heart"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Heart Disease"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_condition_hypertension"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Hypertension"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_condition_thyroid"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Thyroid"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                    </com.google.android.material.chip.ChipGroup>

                    <!-- ── Section: Allergies (chips) ─────────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ALLERGIES"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chip_group_allergies"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        app:singleSelection="false">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_allergy_nuts"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Nuts"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_allergy_gluten"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gluten"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_allergy_dairy"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Dairy"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_allergy_shellfish"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Shellfish"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chip_allergy_soy"
                            style="@style/Widget.MaterialComponents.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Soy"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            app:chipBackgroundColor="@color/surface_elevated"
                            app:checkedIconTint="@color/accent_green"
                            app:chipStrokeColor="@color/surface_elevated"
                            app:chipStrokeWidth="1dp" />

                    </com.google.android.material.chip.ChipGroup>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_elevated"
                        android:layout_marginBottom="20dp" />

                    <!-- ── Section: Diet Goal (dropdown) ─────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="DIET GOAL"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_diet_goal"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        android:hint="Select goal"
                        app:hintTextColor="@color/text_secondary"
                        android:layout_marginBottom="16dp">

                        <AutoCompleteTextView
                            android:id="@+id/actv_diet_goal"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:paddingHorizontal="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- ── Section: Lifestyle (dropdown) ─────────────── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="LIFESTYLE"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_lifestyle"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        android:hint="Select lifestyle"
                        app:hintTextColor="@color/text_secondary"
                        android:layout_marginBottom="20dp">

                        <AutoCompleteTextView
                            android:id="@+id/actv_lifestyle"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:inputType="none"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp"
                            android:paddingHorizontal="12dp" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/surface_elevated"
                        android:layout_marginBottom="20dp" />

                    <!-- ── Section: Custom Note (optional free text) ──── -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ANYTHING ELSE? (optional)"
                        android:textColor="@color/accent_green"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/til_custom_note"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:boxBackgroundColor="@color/surface_elevated"
                        app:boxStrokeColor="@color/surface_elevated"
                        app:hintEnabled="false"
                        android:layout_marginBottom="12dp">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_custom_note"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="e.g. I avoid processed sugar"
                            android:minLines="2"
                            android:maxLines="4"
                            android:inputType="textMultiLine"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Step 2 error -->
                    <TextView
                        android:id="@+id/tv_signup_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text=""
                        android:textColor="@color/error"
                        android:textSize="13sp"
                        android:visibility="gone" />

                    <!-- Create Account button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_signup"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:text="Create Account"
                        android:textSize="15sp"
                        android:textColor="@color/background_dark"
                        android:textStyle="bold"
                        app:backgroundTint="@color/accent_green"
                        app:cornerRadius="26dp" />

                    <!-- Back to Step 1 -->
                    <TextView
                        android:id="@+id/tv_back_to_step1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="12dp"
                        android:text="← Back"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        android:background="?attr/selectableItemBackground"
                        android:paddingHorizontal="4dp" />

                </LinearLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Login redirect -->
        <LinearLayout
            android:id="@+id/ll_login_redirect"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/card_signup">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_go_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log in"
                android:textColor="@color/accent_green"
                android:textSize="14sp"
                android:textStyle="bold"
                android:background="?attr/selectableItemBackground"
                android:paddingHorizontal="2dp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
