<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    tools:context=".presentation.activities.ScanActivity">

    <!-- LAYER 1 — Live camera feed -->
    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- LAYER 2 — Vignette overlay (semi-transparent dark edges) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_vignette" />

    <!-- LAYER 3 — Captured image (shown after photo is taken) -->
    <ImageView
        android:id="@+id/iv_captured"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:background="#A6000000"
        android:visibility="gone"
        tools:src="@android:drawable/ic_menu_camera" />

    <!-- LAYER 4 — Reticle (L-shaped teal corners) -->
    <FrameLayout
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:layout_gravity="center"
        android:layout_marginBottom="48dp">

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|start"
            android:background="@drawable/ic_reticle_tl" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="top|end"
            android:background="@drawable/ic_reticle_tr" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|start"
            android:background="@drawable/ic_reticle_bl" />

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom|end"
            android:background="@drawable/ic_reticle_br" />
    </FrameLayout>

    <!-- LAYER 5 — Top controls row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="16dp">

        <!-- Close button -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="✕"
            android:textSize="18sp"
            android:textColor="@color/on_surface"
            android:background="@drawable/bg_glass_btn" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Flash button -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⚡"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:background="@drawable/bg_glass_btn"
            android:layout_marginEnd="12dp" />

        <!-- Grid/settings button -->
        <TextView
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:text="⊞"
            android:textSize="16sp"
            android:textColor="@color/on_surface"
            android:background="@drawable/bg_glass_btn" />
    </LinearLayout>

    <!-- LAYER 6 — Instruction text (below reticle center) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="240dp"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan the ingredients list"
            android:textColor="@color/on_surface"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hold still for best results"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="12sp"
            android:gravity="center"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- LAYER 7 — Permission denied message -->
    <TextView
        android:id="@+id/tv_permission_denied"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:text="@string/camera_permission_denied"
        android:textColor="@color/on_surface_variant"
        android:textSize="16sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:visibility="gone" />

    <!-- LAYER 8 — Error card (no ingredients found) -->
    <LinearLayout
        android:id="@+id/layout_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="64dp"
        android:layout_marginHorizontal="24dp"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="20dp"
        android:elevation="16dp"
        android:background="@drawable/bg_surface_card">

        <TextView
            android:id="@+id/tv_error_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No ingredients detected"
            android:textColor="@color/error"
            android:textSize="18sp"
            android:textStyle="bold"
            android:fontFamily="@font/plus_jakarta_sans"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/tv_error_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try scanning a food label or packaged product"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- LAYER 9 — Bottom capture controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Gallery shortcut -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="🖼"
                android:textSize="18sp"
                android:background="@drawable/bg_glass_btn" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Gallery"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="10sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Capture button -->
        <FrameLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center">

            <!-- Glow ring -->
            <View
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:background="@drawable/bg_capture_glow"
                android:alpha="0.25"
                android:layout_gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_capture"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:elevation="12dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:clickable="true"
                android:focusable="true"
                app:cornerRadius="40dp"
                app:strokeColor="@color/brand_red"
                app:strokeWidth="4dp"
                app:backgroundTint="@color/surface_container"
                app:icon="@drawable/ic_scan_camera"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:iconSize="32dp"
                app:iconTint="@color/brand_red" />
        </FrameLayout>

        <!-- Mode toggle -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:gravity="center"
                android:text="↻"
                android:textSize="20sp"
                android:textColor="@color/on_surface"
                android:background="@drawable/bg_glass_btn" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Flip"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="10sp"
                android:gravity="center" />
        </LinearLayout>
    </LinearLayout>

    <!-- LAYER 10 — Loading overlay -->
    <LinearLayout
        android:id="@+id/layout_loading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:elevation="12dp"
        android:visibility="gone">

        <ProgressBar
            android:id="@+id/progress_loading"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:indeterminateTint="@color/brand_red" />

        <TextView
            android:id="@+id/tv_loading"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Decoding..."
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:gravity="center" />
    </LinearLayout>

    <!-- LAYER 11 — Retake + Confirm buttons (post-capture) -->
    <LinearLayout
        android:id="@+id/layout_review_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="12dp"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_retake"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:layout_marginEnd="16dp"
            android:text="@string/btn_retake"
            android:textColor="@color/on_surface"
            android:textSize="16sp"
            android:fontFamily="@font/plus_jakarta_sans"
            app:backgroundTint="@color/surface_container_highest"
            app:cornerRadius="28dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_confirm"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:text="@string/btn_confirm"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:fontFamily="@font/plus_jakarta_sans"
            android:background="@drawable/bg_button_primary"
            app:backgroundTint="@null"
            app:cornerRadius="28dp" />
    </LinearLayout>

</FrameLayout>
