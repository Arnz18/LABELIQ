<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- ── Toolbar ─────────────────────────────────────────────── -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/background_dark"
        android:elevation="4dp"
        app:title="Scan Detail"
        app:titleTextColor="@color/white"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <!-- ── Scrollable content ──────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ── SCANNED IMAGE ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp"
                app:cardPreventCornerOverlap="false">

                <ImageView
                    android:id="@+id/iv_scan_image"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:background="#1A1A1A"
                    android:contentDescription="Scanned label image" />

            </com.google.android.material.card.MaterialCardView>

            <!-- ── HEADER CARD: Status + Timestamp ─────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detail_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_detail_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="48sp"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_marginBottom="12dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#33FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:id="@+id/tv_detail_timestamp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="13sp"
                        android:textColor="#BDBDBD"
                        android:gravity="center"
                        android:drawablePadding="6dp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── HIGH RISK CARD ───────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detail_high"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#B71C1C">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌  High Risk"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFCDD2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detail_high_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#FFEBEE"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── MODERATE CARD ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detail_moderate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#E65100">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️  Moderate"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFE0B2"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detail_moderate_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#FFF3E0"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── SAFE CARD ─────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_detail_safe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:visibility="gone"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="#1B5E20">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅  Safe"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#A5D6A7"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:id="@+id/tv_detail_safe_items"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#E8F5E9"
                        android:lineSpacingMultiplier="1.6" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── No ingredients note (shown when all lists empty) -->
            <TextView
                android:id="@+id/tv_detail_no_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No ingredient data recorded for this scan."
                android:textColor="#757575"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="24dp"
                android:visibility="gone" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</LinearLayout>
