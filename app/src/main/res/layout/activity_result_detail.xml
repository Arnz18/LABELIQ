<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#A61C1B1B"
        android:elevation="0dp"
        app:title="Scan Detail"
        app:titleTextColor="@color/on_surface"
        app:navigationIcon="@drawable/ic_arrow_back" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- SCANNED IMAGE -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_surface_card">

                <ImageView
                    android:id="@+id/iv_scan_image"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:scaleType="centerCrop"
                    android:background="#1A1A1A"
                    android:contentDescription="Scanned label image" />
            </FrameLayout>

            <!-- HEADER CARD -->
            <FrameLayout
                android:id="@+id/card_detail_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:background="@drawable/bg_surface_card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="32dp"
                    android:gravity="center_horizontal">

                    <TextView
                        android:id="@+id/tv_detail_icon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="64sp"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/on_surface"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:letterSpacing="-0.02"
                        android:gravity="center"
                        android:layout_marginBottom="24dp" />

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="#1AFFFFFF"
                        android:layout_marginBottom="24dp" />

                    <TextView
                        android:id="@+id/tv_detail_timestamp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/on_surface_variant"
                        android:fontFamily="@font/plus_jakarta_sans"
                        android:gravity="center"
                        android:drawablePadding="6dp" />
                </LinearLayout>
            </FrameLayout>

            <!-- HIGH RISK -->
            <LinearLayout
                android:id="@+id/card_detail_high"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:background="@drawable/bg_surface_card"
                android:padding="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Concerns"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_primary_container"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_button_primary"
                    app:backgroundTint="@color/primary_container"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_detail_high_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- NEUTRAL -->
            <LinearLayout
                android:id="@+id/card_detail_moderate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:visibility="gone"
                android:background="@drawable/bg_surface_card"
                android:padding="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Neutral Ingredients"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#3A2600"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_button_primary"
                    app:backgroundTint="#FFBA35"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_detail_moderate_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <!-- SAFE -->
            <LinearLayout
                android:id="@+id/card_detail_safe"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                android:visibility="gone"
                android:background="@drawable/bg_surface_card"
                android:padding="24dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Benefits"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/on_secondary_container"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:background="@drawable/bg_button_primary"
                    app:backgroundTint="@color/secondary_container"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:layout_marginBottom="16dp" />

                <TextView
                    android:id="@+id/tv_detail_safe_items"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="16sp"
                    android:textColor="@color/on_surface"
                    android:fontFamily="@font/plus_jakarta_sans"
                    android:lineSpacingMultiplier="1.6" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_detail_no_data"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="No ingredient data recorded for this scan."
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="14sp"
                android:gravity="center"
                android:paddingTop="24dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
