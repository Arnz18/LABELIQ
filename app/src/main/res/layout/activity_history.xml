<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <!-- ── Custom Top Bar ─────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@color/background">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="wrap_content"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            android:elevation="0dp"
            app:navigationIcon="?attr/homeAsUpIndicator" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="@color/brand_red"
            android:textSize="20sp"
            android:textStyle="bold"
            android:letterSpacing="-0.03"
            android:fontFamily="@font/plus_jakarta_sans" />
    </LinearLayout>

    <!-- ── Hero Header ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan History"
            android:textColor="@color/on_surface"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="30sp"
            android:textStyle="bold"
            android:letterSpacing="-0.03" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your nutritional intelligence record"
            android:textColor="@color/on_surface_variant"
            android:fontFamily="@font/plus_jakarta_sans"
            android:textSize="14sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- ── Stats Bento Grid ───────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_surface_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/brand_red"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="28sp"
                android:textStyle="bold"
                android:id="@+id/tv_total_scans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Scans"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/bg_surface_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="—"
                android:textColor="@color/secondary"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="28sp"
                android:textStyle="bold"
                android:id="@+id/tv_safe_scans" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Safe Choices"
                android:textColor="@color/on_surface_variant"
                android:fontFamily="@font/plus_jakarta_sans"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- ── Empty state ────────────────────────────────────── -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No scans yet.\nScan a product label to see history here."
        android:textColor="@color/on_surface_variant"
        android:textSize="16sp"
        android:fontFamily="@font/plus_jakarta_sans"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone" />

    <!-- ── History list ───────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_history"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp"
        android:clipToPadding="false" />

</LinearLayout>
