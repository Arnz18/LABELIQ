<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — MaterialComponents DayNight NoActionBar -->
    <style name="Theme.LabelIQ" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSecondaryVariant">@color/secondary_container</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface_container_low</item>
        <item name="colorOnBackground">@color/on_background</item>
        <item name="colorOnSurface">@color/on_surface</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>

        <!-- Font Family -->
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="fontFamily">@font/plus_jakarta_sans</item>
    </style>

    <!-- Toolbar title appearance -->
    <style name="ToolbarTitle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/on_surface</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">-0.02</item>
    </style>

</resources>
