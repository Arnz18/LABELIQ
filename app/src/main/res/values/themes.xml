<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme — Material3 / AppCompat dark -->
    <style name="Theme.LabelIQ" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryVariant">@color/accent_green_dim</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent_green_dim</item>
        <item name="colorSecondaryVariant">@color/accent_green_dim</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background / surface -->
        <item name="android:colorBackground">@color/background_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Error -->
        <item name="colorError">@color/error</item>
    </style>

</resources>
